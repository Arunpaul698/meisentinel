# ── VirusTotal ────────────────────────────────────────────────────────────────
# Free API key from https://www.virustotal.com/gui/join-us
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google Workspace OAuth ────────────────────────────────────────────────────
# Create an OAuth 2.0 client ID at https://console.cloud.google.com/
# Application type: Web application
# Authorized redirect URIs to register (add both):
#   https://meisentinel.onrender.com/auth/google/callback   ← production
#   https://<your-ngrok-id>.ngrok-free.app/auth/google/callback  ← local testing
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=https://meisentinel.onrender.com/auth/google/callback
GOOGLE_FRONTEND_URL=https://meisentis.com/oauth.html

# ── MCP server auth (optional) ────────────────────────────────────────────────
# If set, all /mcp/* endpoints require: Authorization: Bearer <token>
# Leave blank to allow open access (dev/local)
MEISENTIS_MCP_TOKEN=

# ── Database (Tier B — not yet active) ───────────────────────────────────────
# PostgreSQL connection string for scan history persistence
# Provision via Render Postgres or Supabase
DATABASE_URL=postgresql://user:password@host:5432/meisentis
